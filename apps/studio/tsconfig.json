{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"paths": {
			"@codingcatdev/shared/*": [
				"../../packages/shared/*"
			]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx"
	]
}
