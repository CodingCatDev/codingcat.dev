{
  "name": "cloudinary-to-sanity-migration",
  "version": "1.0.0",
  "description": "Migration tool to copy referenced Cloudinary assets to Sanity and update document references",
  "type": "module",
  "scripts": {
    "migrate": "node migrate.mjs",
    "migrate:dry-run": "node migrate.mjs --dry-run",
    "migrate:phase1": "node migrate.mjs --phase=1",
    "migrate:phase2": "node migrate.mjs --phase=2",
    "migrate:phase3": "node migrate.mjs --phase=3",
    "migrate:phase4": "node migrate.mjs --phase=4"
  },
  "dependencies": {
    "@sanity/client": "^6.24.1",
    "node-fetch": "^2.7.0",
    "dotenv": "^16.4.7",
    "p-limit": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}