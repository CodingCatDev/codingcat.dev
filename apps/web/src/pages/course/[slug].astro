---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Badge from "@/components/Badge.astro";
import Avatar from "@/components/Avatar.astro";
import ContentCard from "@/components/ContentCard.astro";
import { PortableText } from "astro-portabletext";
import { loadQuery, urlForImage } from "@/utils/sanity";
import { courseQuery, lessonsInCourseQuery } from "@/lib/queries";
import { parseYoutubeVideoId, youtubeEmbedSrc } from "@/lib/youtube";

export const prerender = false;

const { slug } = Astro.params;
const draftMode = Astro.cookies.has("__sanity_preview");
const perspective = Astro.url.searchParams.get("sanity-preview-perspective") ?? undefined;
const previewDataset = Astro.cookies.get("__sanity_preview_dataset")?.value ?? undefined;

const [{ data: course }, { data: courseWithLessons }] = await Promise.all([
  loadQuery<any>({
    query: courseQuery,
    params: { courseSlug: slug },
    draftMode,
    perspective,
    dataset: previewDataset,
  }),
  loadQuery<any>({
    query: lessonsInCourseQuery,
    params: { courseSlug: slug },
    draftMode,
    perspective,
    dataset: previewDataset,
  }),
]);

if (!course?._id) {
  return Astro.redirect("/404");
}

const coverUrl = course.coverImage
  ? urlForImage(course.coverImage).width(1200).height(630).format("webp").url()
  : null;

const formattedDate = course.date
  ? new Date(course.date).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;

const siteUrl = Astro.url.origin;
const displayTitle = course.title;
const displayDescription = course.excerpt;
const ogImage = coverUrl ?? `${siteUrl}/api/og/default.png?title=${encodeURIComponent(course.title)}`;

const showLockedHint = Astro.url.searchParams.has("locked");

const courseYoutubeId = parseYoutubeVideoId(course.youtube);
---

<BaseLayout title={`${displayTitle} — CodingCat.dev`} description={displayDescription} ogImage={ogImage}>
  <main class="py-12">
    <Container>
      <nav class="text-sm text-[--text-tertiary] mb-6">
        <a href="/courses" class="hover:text-primary transition-colors">Courses</a>
        <span class="mx-2">/</span>
        <span class="text-[--text-secondary]">{course.title}</span>
      </nav>

      {showLockedHint && (
        <div
          class="mb-8 rounded-xl border border-amber-500/40 bg-amber-500/10 px-4 py-3 text-[--text-secondary]"
          role="status"
        >
          Sign in to unlock this lesson, or upgrade to access paid course content.
          <a href="/login" class="ml-2 font-medium text-primary hover:underline">Sign in</a>
        </div>
      )}

      <article>
        <header class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <Badge type="course" />
            {formattedDate && (
              <time datetime={course.date} class="text-sm text-[--text-tertiary]">{formattedDate}</time>
            )}
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-[--text] mb-4">{course.title}</h1>
          {course.excerpt && <p class="text-lg text-[--text-secondary] max-w-3xl">{course.excerpt}</p>}

          <div class="flex flex-wrap items-center gap-4 mt-6">
            {course.author?.map((a: any) => {
              const aImg = a.coverImage ? urlForImage(a.coverImage).width(48).height(48).url() : undefined;
              return (
                <a href={`/author/${a.slug}`} class="flex items-center gap-2 hover:text-primary transition-colors">
                  <Avatar src={aImg} name={a.title} size="sm" />
                  <span class="text-sm font-medium text-[--text-secondary]">{a.title}</span>
                </a>
              );
            })}
          </div>
        </header>

        {coverUrl && (
          <img
            src={coverUrl}
            alt={course.title}
            width={1200}
            height={630}
            class="w-full rounded-xl mb-8 aspect-video object-cover"
          />
        )}

        {courseYoutubeId && (
          <div class="aspect-video mb-8 rounded-xl overflow-hidden">
            <iframe
              src={youtubeEmbedSrc(courseYoutubeId)}
              class="w-full h-full"
              referrerpolicy="strict-origin-when-cross-origin"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              loading="lazy"
              title="Course video"
            />
          </div>
        )}

        {course.content?.length > 0 && (
          <div
            class="prose prose-lg prose-invert max-w-none mb-16
            prose-headings:text-[--text] prose-headings:font-bold
            prose-p:text-[--text-secondary]
            prose-a:text-primary prose-a:no-underline hover:prose-a:underline
            prose-strong:text-[--text]
            prose-code:text-primary prose-code:bg-[--surface] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
            prose-pre:bg-[--surface] prose-pre:border prose-pre:border-[--border] prose-pre:rounded-xl
            prose-blockquote:border-primary prose-blockquote:text-[--text-secondary]
            prose-li:text-[--text-secondary]
            prose-img:rounded-xl"
          >
            <PortableText value={course.content} />
          </div>
        )}

        {courseWithLessons?.sections?.length > 0 && (
          <section class="border-t border-[--border] pt-12">
            <h2 class="text-2xl md:text-3xl font-bold text-[--text] mb-8">Lessons</h2>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {courseWithLessons.sections.flatMap((section: any) =>
                (section.lesson ?? []).map((lesson: any) => (
                  <div>
                    <ContentCard
                      title={lesson.title}
                      url={`/course/${slug}/lesson/${lesson.slug}`}
                      type="course"
                      thumbnail={lesson.coverImage}
                      authorName={course.author?.[0]?.title}
                      authorImage={course.author?.[0]?.coverImage}
                      metadata={section.title ? `${section.title}` : undefined}
                    />
                    {lesson.locked && course.stripeProduct && (
                      <p class="text-xs text-[--text-tertiary] mt-2 px-1">Included with course access</p>
                    )}
                  </div>
                )),
              )}
            </div>
          </section>
        )}
      </article>
    </Container>
  </main>
</BaseLayout>
