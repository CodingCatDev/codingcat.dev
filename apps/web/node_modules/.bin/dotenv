#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/daytona/codingcat.dev/node_modules/.pnpm/dotenv-cli@11.0.0/node_modules/dotenv-cli/node_modules:/home/daytona/codingcat.dev/node_modules/.pnpm/dotenv-cli@11.0.0/node_modules:/home/daytona/codingcat.dev/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/daytona/codingcat.dev/node_modules/.pnpm/dotenv-cli@11.0.0/node_modules/dotenv-cli/node_modules:/home/daytona/codingcat.dev/node_modules/.pnpm/dotenv-cli@11.0.0/node_modules:/home/daytona/codingcat.dev/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../dotenv-cli/cli.js" "$@"
else
  exec node  "$basedir/../dotenv-cli/cli.js" "$@"
fi
