---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { sanityFetch } from "@/utils/sanity";

// Fetch latest posts from Sanity
const posts = await sanityFetch<Array<{
  _id: string;
  title: string;
  slug: { current: string };
  _type: string;
  excerpt?: string;
}>>(
  `*[_type == "post" && defined(slug.current)] | order(_createdAt desc)[0...10] {
    _id, title, slug, _type, excerpt
  }`
);
---

<BaseLayout title="Home">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold mb-8">CodingCat.dev</h1>
    <p class="text-lg text-muted-foreground mb-8">Purrfect Web Tutorials</p>
    
    <section>
      <h2 class="text-2xl font-semibold mb-4">Latest Posts</h2>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a href={`/post/${post.slug.current}`} class="block p-6 rounded-lg border hover:border-primary transition-colors">
            <h3 class="text-xl font-medium mb-2">{post.title}</h3>
            {post.excerpt && <p class="text-muted-foreground">{post.excerpt}</p>}
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
